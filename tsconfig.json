{
  "compilerOptions": {
    /* Cấu hình cơ bản */
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    // "lib" option removed as per user's complete file.
    /* Cấu hình Output - Quan trọng để Render chạy được */
    "outDir": "./dist",
    "noEmit": false,           // Phải để false để tạo ra file .js
    "allowJs": true,
    // "sourceMap" option removed as per user's complete file.
    /* Cấu hình Interop & Kiểm tra lỗi */
    "esModuleInterop": true,
    // "forceConsistentCasingInFileNames" option removed as per user's complete file.
    "strict": true,
    "skipLibCheck": true,
    /* Cấu hình cho React/Vite */
    "jsx": "react-jsx",
    "isolatedModules": true,
    /* Đường dẫn Alias */
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "server.ts",      // File backend của bạn
    "src/types/**/*.ts" // Chỉ include các file type cho backend
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.tsx", // Exclude frontend React files
    "src/**/*.ts"   // Exclude frontend TS files (non-tsx)
  ]
}