{
  "compilerOptions": {
    /* Cấu hình cơ bản */
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node", // Giữ là node để tương thích tốt với backend Express
    
    /* Cấu hình Output */
    "outDir": "./dist",
    "noEmit": false,           // Cho phép tạo file nếu bạn chạy tsc độc lập
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,   // Bắt buộc khi dùng esbuild/swc
    
    /* Cấu hình Interop & Kiểm tra lỗi */
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,      // Tránh lỗi từ các thư viện node_modules
    
    /* Cấu hình cho React (để esbuild không lỗi khi quét qua src) */
    "jsx": "react-jsx",
    
    /* Đường dẫn Alias - Khớp với cấu trúc thư mục của bạn */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "server.ts",
    "src/**/*"                 // Bao gồm toàn bộ src để check type cho chắc chắn
  ],
  "exclude": [
    "node_modules",
    "dist",
    "client"                   // Loại bỏ thư mục client nếu nó nằm riêng biệt
  ]
}